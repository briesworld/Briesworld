<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Brie’s Spring Website</title>

  <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;700&display=swap" rel="stylesheet">

  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: 'Quicksand', sans-serif;
      background: linear-gradient(to bottom, #f7ffd8, #fff8d6, #ffe8f2, #e7ffe8);
      color: #4f5f3c;
      line-height: 1.6;
      overflow-x: hidden;
    }

    a {
      text-decoration: none;
      color: inherit;
    }

    .navbar {
      position: sticky;
      top: 0;
      z-index: 1000;
      background: rgba(255, 255, 255, 0.78);
      backdrop-filter: blur(10px);
      padding: 14px 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid rgba(218, 240, 191, 0.8);
      box-shadow: 0 4px 14px rgba(180, 212, 137, 0.15);
    }

    .logo {
      font-size: 1.3rem;
      font-weight: 700;
      color: #7bb661;
    }

    .nav-links {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }

    .nav-links a {
      color: #6b8750;
      font-weight: 700;
      padding: 8px 14px;
      border-radius: 999px;
      transition: 0.2s ease;
    }

    .nav-links a:hover {
      background: #eefad7;
    }

    .hero {
      min-height: 88vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 50px 20px;
    }

    .hero-card {
      max-width: 950px;
      width: 100%;
      background: rgba(255, 255, 255, 0.82);
      border-radius: 32px;
      padding: 40px;
      box-shadow: 0 12px 35px rgba(180, 212, 137, 0.18);
      text-align: center;
      border: 2px solid #eefad7;
    }

    .hero-card h1 {
      font-size: 2.6rem;
      color: #7bb661;
      margin-bottom: 14px;
      min-height: 3.2rem;
    }

    .hero-card p {
      font-size: 1.05rem;
      max-width: 650px;
      margin: 0 auto 24px;
      color: #6f7a59;
    }

    .button-group {
      display: flex;
      gap: 14px;
      justify-content: center;
      flex-wrap: wrap;
      margin-top: 10px;
    }

    .btn,
    .small-btn {
      display: inline-block;
      padding: 12px 22px;
      border-radius: 999px;
      font-weight: 700;
      transition: 0.25s ease;
      cursor: pointer;
      border: none;
      font-family: inherit;
    }

    .btn-main,
    .small-btn {
      background: #a7d97f;
      color: white;
      box-shadow: 0 0 15px rgba(167, 217, 127, 0.4);
    }

    .btn-main:hover,
    .small-btn:hover {
      transform: translateY(-2px);
      background: #92cc64;
    }

    .btn-light {
      background: #fff7c9;
      color: #7b8f4e;
      border: 2px solid #f4ec9d;
    }

    .btn-light:hover {
      transform: translateY(-2px);
      background: #fff2a8;
    }

    .section {
      padding: 70px 20px;
    }

    .section-title {
      text-align: center;
      font-size: 2rem;
      color: #7bb661;
      margin-bottom: 18px;
    }

    .section-subtext {
      text-align: center;
      max-width: 650px;
      margin: 0 auto 36px;
      color: #6f7a59;
    }

    .divider {
      text-align: center;
      font-size: 22px;
      color: #94c973;
      padding: 0 20px 12px;
    }

    .cards {
      max-width: 1100px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
      gap: 22px;
    }

    .card {
      background: rgba(255, 255, 255, 0.84);
      border-radius: 28px;
      padding: 24px;
      box-shadow: 0 10px 24px rgba(180, 212, 137, 0.14);
      transition: 0.3s;
      border: 2px solid #eefad7;
      text-align: center;
    }

    .card:hover {
      transform: translateY(-5px);
      box-shadow: 0 0 20px rgba(167, 217, 127, 0.35);
    }

    .card h3 {
      margin-bottom: 10px;
      color: #7bb661;
    }

    .gallery {
      max-width: 1100px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 18px;
    }

    .gallery-box {
      background: rgba(255, 255, 255, 0.84);
      border-radius: 28px;
      min-height: 220px;
      padding: 14px;
      box-shadow: 0 10px 22px rgba(180, 212, 137, 0.14);
      overflow: hidden;
      transition: 0.3s;
      border: 2px solid #eefad7;
    }

    .gallery-box:hover {
      transform: translateY(-4px);
    }

    .gallery-box img {
      width: 100%;
      height: 280px;
      object-fit: cover;
      border-radius: 20px;
      transition: transform 0.3s ease;
      display: block;
    }

    .gallery-box img:hover {
      transform: scale(1.04);
    }

    .about-box,
    .quote-wrap,
    .message-wrap {
      max-width: 850px;
      margin: 0 auto;
      background: rgba(255, 255, 255, 0.84);
      border-radius: 28px;
      padding: 30px;
      box-shadow: 0 10px 24px rgba(180, 212, 137, 0.14);
      text-align: center;
      border: 2px solid #eefad7;
    }

    .message-wrap input {
      width: min(100%, 420px);
      padding: 12px 14px;
      border-radius: 999px;
      border: 2px solid #dff0bc;
      outline: none;
      font-family: inherit;
      margin-bottom: 12px;
    }

    #quoteBox,
    #output {
      margin-top: 14px;
      color: #6f7a59;
      font-weight: 700;
      min-height: 24px;
    }

    .floating-note {
      position: fixed;
      bottom: 12px;
      right: 12px;
      opacity: 0.85;
      font-size: 12px;
      background: rgba(255, 255, 255, 0.78);
      padding: 8px 12px;
      border-radius: 999px;
      z-index: 999;
      color: #7bb661;
      border: 1px solid #eefad7;
    }

    .flower-decor {
      position: fixed;
      top: 18%;
      left: 8%;
      font-size: 22px;
      pointer-events: none;
      z-index: 1;
    }

    .footer {
      padding: 28px 20px 40px;
      text-align: center;
      color: #6f7a59;
    }

    @media (max-width: 700px) {
      .hero-card {
        padding: 28px 20px;
      }

      .hero-card h1 {
        font-size: 2rem;
      }

      .navbar {
        flex-direction: column;
        gap: 10px;
      }

      .gallery-box img {
        height: 220px;
      }
    }
  </style>
</head>
<body>
  <div class="flower-decor">🌼</div>

  <nav class="navbar">
    <div class="logo">🌷 Brie’s Spring World</div>
    <div class="nav-links">
      <a href="#home">Home</a>
      <a href="#favorites">Favorites</a>
      <a href="#gallery">Gallery</a>
      <a href="#about">About</a>
      <a href="#quotes">Quotes</a>
      <a href="#message">Message</a>
    </div>
  </nav>

  <section class="hero" id="home">
    <div class="hero-card">
      <h1 id="typeText"></h1>
      <p>
        A fresh little spring corner full of flowers, sunshine, soft colors,
        and sweet vibes 🌸☀️
      </p>

      <div class="button-group">
        <a href="#gallery" class="btn btn-main">See My Garden</a>
        <a href="#about" class="btn btn-light">About Me</a>
      </div>
    </div>
  </section>

  <section class="section" id="favorites">
    <h2 class="section-title">Spring Favorites 🌼</h2>
    <p class="section-subtext">
      Soft colors, flowers, sunshine, sweet treats, and cozy happy energy.
    </p>

    <div class="cards">
      <div class="card">
        <h3>🌷 Flowers</h3>
        <p>Tulips, daisies, cherry blossoms, and anything soft and pretty.</p>
      </div>

      <div class="card">
        <h3>☀️ Sunshine</h3>
        <p>Warm light, fresh air, and cute little outdoor moments.</p>
      </div>

      <div class="card">
        <h3>🧺 Picnics</h3>
        <p>Snacks, blankets, fruit, and dreamy spring afternoons.</p>
      </div>

      <div class="card">
        <h3>🎨 Art</h3>
        <p>Drawing cute things inspired by spring colors and nature.</p>
      </div>
    </div>
  </section>

  <div class="divider">✿･ﾟ: *✿･ﾟ:* 🌷 *:･ﾟ✿*:･ﾟ✿</div>

  <section class="section" id="gallery">
    <h2 class="section-title">Spring Gallery 🌸</h2>
    <p class="section-subtext">A little wall of pretty spring inspiration.</p>

    <div class="gallery">
      <div class="gallery-box">
        <img src="https://images.unsplash.com/photo-1527061011665-3652c757a4d4?auto=format&fit=crop&w=900&q=80" alt="Spring flowers">
      </div>

      <div class="gallery-box">
        <img src="https://images.unsplash.com/photo-1490750967868-88aa4486c946?auto=format&fit=crop&w=900&q=80" alt="Flower field">
      </div>

      <div class="gallery-box">
        <img src="https://images.unsplash.com/photo-1457089328109-e5d9bd499191?auto=format&fit=crop&w=900&q=80" alt="Spring picnic">
      </div>
    </div>
  </section>

  <div class="divider">✿･ﾟ: *✿･ﾟ:* 🐝 *:･ﾟ✿*:･ﾟ✿</div>

  <section class="section" id="about">
    <h2 class="section-title">About This Page 🌿</h2>
    <div class="about-box">
      <p>
        This is my spring-themed website with soft colors, flowers, and fresh happy vibes.
        It feels light, cute, and peaceful 💚
      </p>
    </div>
  </section>

  <section class="section" id="quotes">
    <h2 class="section-title">Spring Quotes 🌼</h2>
    <div class="quote-wrap">
      <button class="small-btn" onclick="quote()">🌸 New Quote</button>
      <p id="quoteBox"></p>
    </div>
  </section>

  <section class="section" id="message">
    <h2 class="section-title">Leave a Note 🌷</h2>
    <div class="message-wrap">
      <input type="text" id="messageInput" placeholder="Write something sweet 🌼">
      <br>
      <button class="small-btn" onclick="showMsg()">Send</button>
      <p id="output"></p>
    </div>
  </section>

  <footer class="footer">
    <h3>Thanks for visiting my spring page 🌸</h3>
    <p>Made with flowers, sunshine, and soft little details ☀️</p>
  </footer>

  <div class="floating-note">spring vibes only 🌼</div>

  <script>
    let text = "Welcome to Brie’s Spring Website 🌷";
    let i = 0;

    function type() {
      if (i < text.length) {
        document.getElementById("typeText").textContent += text.charAt(i);
        i++;
        setTimeout(type, 50);
      }
    }

    type();

    function quote() {
      const quotes = [
        "Bloom in your own time 🌸",
        "Softness can still be strong 🌿",
        "Let yourself grow 🌷",
        "Spring is proof that new things can be beautiful ☀️",
        "Keep blooming, pretty thing 🌼"
      ];
      const random = quotes[Math.floor(Math.random() * quotes.length)];
      document.getElementById("quoteBox").textContent = random;
    }

    function showMsg() {
      const msg = document.getElementById("messageInput").value.trim();
      document.getElementById("output").textContent = msg ? "You said: " + msg : "Type something first 🌷";
    }

    document.addEventListener("click", function(e) {
      const flower = document.createElement("div");
      flower.textContent = "🌸";
      flower.style.position = "fixed";
      flower.style.left = e.clientX + "px";
      flower.style.top = e.clientY + "px";
      flower.style.fontSize = "20px";
      flower.style.pointerEvents = "none";
      flower.style.zIndex = "9999";

      document.body.appendChild(flower);

      setTimeout(() => {
        flower.remove();
      }, 800);
    });

    setInterval(() => {
      const petal = document.createElement("div");
      petal.textContent = "🌼";
      petal.style.position = "fixed";
      petal.style.left = Math.random() * window.innerWidth + "px";
      petal.style.top = "-20px";
      petal.style.fontSize = "18px";
      petal.style.pointerEvents = "none";
      petal.style.zIndex = "9998";

      document.body.appendChild(petal);

      let topPos = -20;
      const fall = setInterval(() => {
        topPos += 2;
        petal.style.top = topPos + "px";
      }, 20);

      setTimeout(() => {
        clearInterval(fall);
        petal.remove();
      }, 4000);
    }, 1400);
  </script>
</body>
</html>
